  Future<void> _loadArtisan() async {
    setState(() => _loadingArtisan = true);
    try {
      final doc = await FirebaseFirestore.instance
          .collection('users')
          .doc(widget.demande.artisanId)
          .get();
      if (mounted) {
        setState(() {
          _artisanData = doc.data();
          _loadingArtisan = false;
