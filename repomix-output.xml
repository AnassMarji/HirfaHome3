    final user = FirebaseAuth.instance.currentUser;

    return Scaffold(
      backgroundColor: AppColors.background,
      body: CustomScrollView(
        slivers: [
          // ── Gradient Hero Header ──────────────────────────────────────────
          SliverToBoxAdapter(
            child: _HeroHeader(
              user: user,
              lang: lang,
              langVM: langVM,
            ),
          ),

          // ── Stats Row ────────────────────────────────────────────────────
          SliverToBoxAdapter(
            child: _StatsRow(demandes: demandes, lang: lang),
