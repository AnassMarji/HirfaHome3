<file path="firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // Helper Functions
    // =============================================

    /// Returns true if the request is from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns the role stored in the user's Firestore document.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    /// Returns true if the authenticated user has the 'admin' role.
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    /// Returns true if the authenticated user has the 'client' role.
    function isClient() {
      return isAuthenticated() && getUserRole() == 'client';
    }

    /// Returns true if the authenticated user has the 'artisan' role.
    function isArtisan() {
      return isAuthenticated() && getUserRole() == 'artisan';
    }

    /// Returns true if the authenticated user is the owner of the document.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Returns the set of fields that changed between the incoming write
    /// and the existing document.
    function affectedFields() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // =============================================
    // Users Collection
    // =============================================
    // - A user can read and write their own document only.
    // - Admin can read all user documents.
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // =============================================
    // Artisans Collection
    // =============================================
    // - Any authenticated user can read artisan profiles.
    // - The artisan themselves can update their own profile,
    //   EXCEPT the 'verifie' and 'note' fields (admin-only).
    // - Admin can write (create / update / delete) any artisan doc.
    match /artisans/{artisanId} {
      allow read: if isAuthenticated();

      // Admin has full write access.
      allow write: if isAdmin();

      // The artisan can update their own profile but cannot touch
      // the admin-controlled fields 'verifie' and 'note'.
      allow update: if isOwner(artisanId)
                    && !affectedFields().hasAny(['verifie', 'note']);
    }

    // =============================================
    // Requests (Demandes) Collection
    // =============================================
    // - Client can create a request if clientId matches their uid.
    // - Client can read their own requests (clientId == uid).
    // - Artisan can read requests assigned to them (artisanId == uid).
    // - Artisan can update only the 'statut' field on their own requests.
    // - Admin can read and write all requests.
    match /requests/{requestId} {
      allow read: if isAdmin()
                  || (isClient()  && resource.data.clientId  == request.auth.uid)
                  || (isArtisan() && resource.data.artisanId == request.auth.uid);

      allow create: if isAdmin()
                    || (isClient() && request.resource.data.clientId == request.auth.uid);

      allow update: if isAdmin()
                    || (isArtisan()
                        && resource.data.artisanId == request.auth.uid
                        && affectedFields().hasOnly(['statut']));

      allow delete: if isAdmin();
    }

    // =============================================
    // Messages Collection
    // =============================================
    // - Authenticated users can read/write messages where they are
    //   the sender or they belong to the parent request
    //   (i.e. they are the client or artisan on the linked request).
    match /messages/{messageId} {
      // True if the user is a participant of the request linked to this message.
      function isRequestParticipant() {
        let req = get(/databases/$(database)/documents/requests/$(resource.data.requestId));
        return req.data.clientId == request.auth.uid
            || req.data.artisanId == request.auth.uid;
      }

      // For create operations, resource doesn't exist yet — check incoming data.
      function isRequestParticipantOnCreate() {
        let req = get(/databases/$(database)/documents/requests/$(request.resource.data.requestId));
        return req.data.clientId == request.auth.uid
            || req.data.artisanId == request.auth.uid;
      }

      allow read: if isAuthenticated()
                  && (resource.data.senderId == request.auth.uid
                      || isRequestParticipant());

      allow create: if isAuthenticated()
                    && (request.resource.data.senderId == request.auth.uid)
                    && isRequestParticipantOnCreate();

      allow update, delete: if isAuthenticated()
                            && resource.data.senderId == request.auth.uid;
    }

    // =============================================
    // Reviews (Avis) Collection
    // =============================================
    // - Authenticated clients can create a review.
    // - clientId on the review must match the writer's uid.
    // - artisanId must reference an existing artisan document.
    // - Any authenticated user can read reviews.
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();

      allow create: if isClient()
                    && request.resource.data.clientId == request.auth.uid
                    && exists(/databases/$(database)/documents/artisans/$(request.resource.data.artisanId));
    }

    // =============================================
    // Categories Collection
    // =============================================
    // - Anyone (even unauthenticated) can read categories.
    // - Only admin can write.
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
